# ============================================================
# Tuskrank API — Environment Variables (Example)
# ============================================================
# Copy to `.env.<environment>` files. Never commit real secrets.

# ============================================================
# Application
# ============================================================
NODE_ENV=development
APP_NAME=tuskrank-api
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=4000

# Global API prefix
API_GLOBAL_PREFIX=api
# Default API version used by URI versioning
API_DEFAULT_VERSION=1

# CORS — comma-separated origins (no trailing slash)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================
# Supabase — Project
# ============================================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=
SUPABASE_JWT_SECRET=

# ============================================================
# Database (PostgreSQL via Supabase)
# ============================================================
# Connection string uses Supabase Pooler in production (port 6543)
# and direct (port 5432) in development. sslmode=require in prod.
DATABASE_URL=
DATABASE_SSL=true
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_QUERY_TIMEOUT_MS=10000

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_REDACT_KEYWORDS=password,authorization,cookie,token,secret

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ============================================================
# Request limits
# ============================================================
REQUEST_BODY_LIMIT=2mb

# ============================================================
# Health Checks
# ============================================================
HEALTH_MEMORY_HEAP_THRESHOLD=400
HEALTH_MEMORY_RSS_THRESHOLD=512

# ============================================================
# Observability (placeholders — wired in later sprints)
# ============================================================
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=tuskrank-api
