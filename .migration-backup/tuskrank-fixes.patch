diff --git a/database/indexes.sql b/database/indexes.sql
index 2d9a0ee..6f244f7 100644
--- a/database/indexes.sql
+++ b/database/indexes.sql
@@ -141,6 +141,19 @@ CREATE INDEX CONCURRENTLY idx_pt_pet_active
     ON product_targeting (product_id, pet_type_id)
     WHERE deleted_at IS NULL AND is_active;
 
+-- NULL-safe uniqueness: treat NULL dimensions as equal to each other
+-- using COALESCE with the zero UUID sentinel so that two rows with the
+-- same product_id + pet_type_id + all-NULL dimensions are rejected.
+CREATE UNIQUE INDEX CONCURRENTLY uq_product_targeting_active_dimensions
+    ON product_targeting (
+        product_id,
+        pet_type_id,
+        COALESCE(life_stage_id, '00000000-0000-0000-0000-000000000000'::uuid),
+        COALESCE(breed_size_id, '00000000-0000-0000-0000-000000000000'::uuid),
+        COALESCE(category_id, '00000000-0000-0000-0000-000000000000'::uuid)
+    )
+    WHERE deleted_at IS NULL;
+
