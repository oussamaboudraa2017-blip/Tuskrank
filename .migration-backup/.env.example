# ============================================================
# Tuskrank — Environment Variables (Example)
# ============================================================
# Copy this file to `.env` and fill in real values.
# Never commit `.env` files.

# ============================================================
# Application
# ============================================================
NODE_ENV=development
APP_ENV=local
APP_NAME=Tuskrank
APP_URL=http://localhost:3000
APP_PORT_WEB=3000
APP_PORT_API=4000
APP_PORT_ADMIN=3001

# ============================================================
# Supabase
# ============================================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=
SUPABASE_JWT_SECRET=

# ============================================================
# Database (PostgreSQL via Supabase)
# ============================================================
DATABASE_URL=
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_SSL=true

# ============================================================
# AI Providers
# ============================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o

# ============================================================
# Search
# ============================================================
SEARCH_PROVIDER=postgres
SEARCH_INDEX_NAME=tuskrank_search

# ============================================================
# Storage (Supabase Storage buckets)
# ============================================================
STORAGE_BUCKET_PRODUCTS=products
STORAGE_BUCKET_BRANDS=brands
STORAGE_BUCKET_UPLOADS=uploads

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================
# Analytics & SEO
# ============================================================
NEXT_PUBLIC_SITE_URL=https://tuskrank.com
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GSC_VERIFICATION=

# ============================================================
# Vercel / Deployment
# ============================================================
VERCEL_ENV=development
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# ============================================================
# Local Docker (docker-compose.yml)
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tuskrank
POSTGRES_PORT=5432
