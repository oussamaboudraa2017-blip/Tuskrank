# ---------- Database (for Docker) ----------
DATABASE_URL=postgres://postgres:postgres@postgres:5432/tuskrank
DATABASE_SSL=false

# ---------- Redis (for Docker) ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL_MS=60000

# ---------- CORS (for development) ----------
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# ---------- General ----------
NODE_ENV=development
APP_PORT=4000
APP_HOST=0.0.0.0
LOG_LEVEL=debug
